{
  "name": "@rckflr/agent-skills-cli",
  "version": "1.0.0",
  "description": "Reference CLI for the agent-skills specification: validate, sync, query, resolve, and exec skills end-to-end with audit log + Cloudflare Workers AI / Ollama / OpenAI embeddings. Stable v1.0 — semver-protected per STABILITY.md.",
  "license": "MIT",
  "author": "Mauricio Perera",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MauricioPerera/agent-skills-cli.git"
  },
  "homepage": "https://github.com/MauricioPerera/agent-skills-cli#readme",
  "bugs": {
    "url": "https://github.com/MauricioPerera/agent-skills-cli/issues"
  },
  "keywords": [
    "agent-skills",
    "llm-tools",
    "mcp-alternative",
    "skill-bank",
    "llms-txt"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agent-skills": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "schemas"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=22"
  }
}
